---
config:
    theme: neutral
    layout: elk
    defaultRenderer: elk
    elk:
        nodePlacementStrategy: NETWORK_SIMPLEX
---

classDiagram
    Cuboid --|> Polyhedron
    Polyhedron ..|> GJKTarget
    Polyhedron ..> CollisionManager: Uses
    CollisionManager ..> GJKTarget: Uses
   
    class CollisionManager {
        + isSeperatingAxis(verts1: Vector3[], verts2: Vector3[], axis: Vector3)$ boolean
        + polygonIntersects(verts1: Vector3[], edges1: Vector3[], verts2: Vector3[], edges2: Vector3[])$ boolean
        + intersects(movable: GJKTarget, immovable: GJKTarget, out outMtv: Vector3)$ boolean
    }

    class Cuboid {
        - obb: OrientedBoundingBox

        + Cuboid(obb: OrientedBoundingBox)
        + getFaceCount() int
        + getFaceVertices(faceIndex: int) Vector3[]
        + getBounds() BoundingBox
        + getNonParallelEdges(faceIndex: int) Vector3[]
    }

    class Polyhedron {
        <<abstract>>

        + getFaceCount()* int
        + getFaceVertices(faceIndex: int)* Vector3[]
        + getAllVertices() Iterable~Vector3~
        + getBounds() BoundingBox*
        + getNonParallelEdges(faceIndex: int) Vector3[]
        + furthestPoint(direction: Vector3, reverse: boolean) Vector3
        + intersects(other: Polyhedron) boolean
        + intersects(immovable: Polyhedron, out outMtv: Vector3) boolean
    }
    class GJKTarget {
        <<interface>>

        + furthestPoint(direction: Vector3, reverse: boolean) Vector3
    }
